# Renombrar este archivo a .env y completar con datos reales
# NUNCA compartir el .env — contiene contraseñas

# ── BASE DE DATOS SQL SERVER ──────────────────────────────
DB_HOST=IP_DEL_SERVIDOR        # Ej: 192.168.1.10 o nombre del servidor
DB_NAME=hse_db
DB_USER=hse_app                # Usuario de APP (no usar sa en producción)
DB_PASSWORD=CONTRASEÑA_APP

# ── EMAIL OFFICE 365 ──────────────────────────────────────
SMTP_USER=tu_correo@empresa.com
SMTP_PASSWORD=tu_contraseña_office365

# Emails que reciben alertas de riesgo ALTO (separados por coma)
SUPERVISORES=supervisor@empresa.com,hse@empresa.com
